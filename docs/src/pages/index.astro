---
// Standalone marketing landing page for The Desk.
// Not a Starlight page — the documentation lives under /docs.
const github = 'https://github.com/emmpaul/the-desk';
const installGuide = '/docs/self-hosting/installation/';
const title = 'The Desk — Self-hosted team chat that lives on your own server';
const description =
	'The Desk is a calm, fast, open-source team chat app you host yourself: channels, threads, reminders, scheduled messages. One container, your hardware, your data.';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
		<link rel="canonical" href="https://the-desk.pages.dev/" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=Instrument+Sans:ital,wght@0,400..700;1,400..700&family=Newsreader:ital,opsz,wght@0,6..72,400..700;1,6..72,400..700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<!-- ============================ NAV ============================ -->
		<header class="nav">
			<div class="nav-inner">
				<a class="brand" href="/">
					<svg width="26" height="26" viewBox="0 0 40 40" aria-hidden="true">
						<polygon points="20,18 36,27 20,36 4,27" fill="#1d1a15" opacity="0.4"></polygon>
						<polygon points="20,11 36,20 20,29 4,20" fill="#1d1a15" opacity="0.7"></polygon>
						<polygon points="20,4 36,13 20,22 4,13" fill="#c9a35c"></polygon>
					</svg>
					<span class="serif brand-name">The Desk</span>
				</a>
				<nav class="nav-links">
					<a class="nav-link" href="#features">Features</a>
					<a class="nav-link" href="#selfhost">Self-hosting</a>
					<a class="nav-link" href="/docs">Docs</a>
					<a class="btn btn-dark btn-sm" href={github}>
						<svg width="13" height="13" viewBox="0 0 24 24" fill="#f3efe4" aria-hidden="true"
							><path
								d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0 1 12 6.84c.85 0 1.71.11 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.16.58.67.48A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10z"
							></path></svg
						>
						GitHub
					</a>
				</nav>
				<button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
					<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
						<path d="M4 7h16"></path><path d="M4 12h16"></path><path d="M4 17h16"></path>
					</svg>
				</button>
			</div>
		</header>

		<!-- ============================ HERO ============================ -->
		<section class="hero">
			<div class="wrap hero-grid">
				<div class="hero-copy">
					<span class="eyebrow-brass serif">
						<svg width="14" height="14" viewBox="0 0 40 40" aria-hidden="true">
							<polygon points="20,18 36,27 20,36 4,27" fill="#7d6023" opacity="0.35"></polygon>
							<polygon points="20,11 36,20 20,29 4,20" fill="#7d6023" opacity="0.6"></polygon>
							<polygon points="20,4 36,13 20,22 4,13" fill="#c9a35c"></polygon>
						</svg>
						Open source, self-hosted team chat
					</span>
					<h1 class="serif hero-title">Team chat that lives on your own server</h1>
					<p class="hero-lede">
						The Desk is a calm, fast messaging app for teams: channels, threads, reminders, scheduled
						messages. One container, your hardware, your data. No per-seat pricing, because there's no
						one to pay.
					</p>
					<div class="hero-actions">
						<a class="btn btn-dark btn-lg" href={installGuide}>
							Deploy in 5 minutes
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"
								><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
							>
						</a>
						<a class="btn btn-outline btn-lg" href="#features">See the app</a>
					</div>
					<div class="hero-install">
						<span class="mono-chip">docker compose pull &amp;&amp; docker compose up -d</span>
						<span>and it's installed. Prebuilt image, no build step.</span>
					</div>
				</div>

				<!-- mini 3-pane workspace preview -->
				<div class="preview">
					<div class="preview-panes">
						<!-- dock -->
						<div class="pane pane-dock">
							<div class="dock-head">
								<svg width="18" height="18" viewBox="0 0 40 40" aria-hidden="true">
									<polygon points="20,18 36,27 20,36 4,27" fill="#1d1a15" opacity="0.4"></polygon>
									<polygon points="20,11 36,20 20,29 4,20" fill="#1d1a15" opacity="0.7"></polygon>
									<polygon points="20,4 36,13 20,22 4,13" fill="#c9a35c"></polygon>
								</svg>
								<span class="serif dock-team">Acme Co</span>
								<svg class="ml-auto" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#9b937f" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
							</div>
							<div class="dock-label">Channels</div>
							<div class="dock-item"><span class="hash-faint">#</span> general</div>
							<div class="dock-item dock-item--active"><span class="hash-brass">#</span> design</div>
							<div class="dock-item"><span class="hash-faint">#</span> engineering <span class="badge-count">3</span></div>
							<div class="dock-item"><span class="hash-faint">#</span> releases</div>
							<div class="dock-label">Direct messages</div>
							<div class="dock-item"><span class="dot dot--on"></span> Jonah Kim</div>
							<div class="dock-item"><span class="dot dot--off"></span> Priya Okafor</div>
						</div>

						<!-- timeline -->
						<div class="pane pane-timeline">
							<div class="tl-head">
								<span class="serif tl-title"><span class="hash-brass">#</span> design</span>
								<span class="tl-sub">· 12 members</span>
							</div>
							<div class="tl-body">
								<div class="msg">
									<div class="avatar av-gold">JK</div>
									<div class="msg-body">
										<span class="msg-meta"><span class="msg-name">Jonah Kim</span> <span class="msg-time">10:42 AM</span></span>
										<span class="msg-text">New brand files are up. Grab the logo pack before tomorrow's review.</span>
										<span class="reactions">
											<span class="reaction reaction--on">👍 4</span>
											<span class="reaction">🎉 2</span>
										</span>
									</div>
								</div>
								<div class="msg">
									<div class="avatar av-green">TB</div>
									<div class="msg-body">
										<span class="msg-meta"><span class="msg-name">Tessa Brandt</span> <span class="msg-time">10:45 AM</span></span>
										<span class="msg-text">Looks great. Starting a thread for the icon feedback.</span>
										<span class="thread-link">
											<span class="stack">
												<span class="stack-a"></span><span class="stack-b"></span>
											</span>
											5 replies · last reply 12 min ago
										</span>
									</div>
								</div>
								<div class="msg">
									<div class="avatar av-ink">MR</div>
									<div class="msg-body">
										<span class="msg-meta"><span class="msg-name">Maya Rivera</span> <span class="msg-time">10:51 AM</span></span>
										<span class="msg-text">Scheduling the go/no-go post for Monday 9 AM so nobody gets pinged over the weekend.</span>
										<span class="scheduled-pill">
											<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#b98e3f" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
											Scheduled · Mon 9:00 AM
										</span>
									</div>
								</div>
							</div>
							<div class="tl-composer">Message #design…</div>
						</div>

						<!-- thread pane -->
						<div class="pane pane-thread">
							<div class="thread-head">
								<span class="serif">Thread</span>
								<svg class="ml-auto" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#9b937f" stroke-width="2" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18"></path><path d="m6 6 12 12"></path></svg>
							</div>
							<div class="thread-body">
								<div class="thread-msg"><div class="avatar avatar-sm av-green">TB</div><span class="thread-text">Icon feedback here please, especially the favicon at 16px.</span></div>
								<div class="thread-msg"><div class="avatar avatar-sm av-rose">SL</div><span class="thread-text">Brass plane reads well even tiny. Ship it.</span></div>
								<div class="thread-msg"><div class="avatar avatar-sm av-gold">JK</div><span class="thread-text">Agreed 🔥</span></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================ POWERED BY ============================ -->
		<section class="powered">
			<div class="wrap powered-grid">
				<div class="powered-intro">
					<span class="eyebrow eyebrow--brass">Powered by</span>
					<h2 class="serif powered-title">A boring stack you already know how to run</h2>
					<p class="powered-lede">One compose file, a handful of containers. No Kubernetes, no exotic dependencies.</p>
				</div>
				<div class="stack-grid">
					<div class="stack-card">
						<img src="https://cdn.simpleicons.org/laravel/f3efe4" alt="Laravel" width="30" height="30" />
						<div class="stack-text"><span class="stack-name">Laravel 13</span><span class="stack-desc">Application framework, queues &amp; scheduler</span></div>
					</div>
					<div class="stack-card">
						<img src="https://cdn.simpleicons.org/vuedotjs/f3efe4" alt="Vue.js" width="30" height="30" />
						<div class="stack-text"><span class="stack-name">Vue 3</span><span class="stack-desc">Frontend, served through Inertia</span></div>
					</div>
					<div class="stack-card">
						<img src="https://cdn.simpleicons.org/inertia/f3efe4" alt="Inertia" width="30" height="30" />
						<div class="stack-text"><span class="stack-name">Inertia</span><span class="stack-desc">Server-driven SPA, no separate API</span></div>
					</div>
					<div class="stack-card">
						<img src="https://cdn.simpleicons.org/postgresql/f3efe4" alt="PostgreSQL" width="30" height="30" />
						<div class="stack-text"><span class="stack-name">PostgreSQL</span><span class="stack-desc">Database, cache, sessions &amp; queue</span></div>
					</div>
					<div class="stack-card">
						<img src="https://cdn.simpleicons.org/meilisearch/f3efe4" alt="Meilisearch" width="30" height="30" />
						<div class="stack-text"><span class="stack-name">Meilisearch</span><span class="stack-desc">Instant full-text message search</span></div>
					</div>
					<div class="stack-card">
						<img src="https://cdn.simpleicons.org/redis/f3efe4" alt="Redis" width="30" height="30" />
						<div class="stack-text"><span class="stack-name">Redis</span><span class="stack-desc">Cache &amp; realtime presence</span></div>
					</div>
					<div class="stack-card stack-card--wide">
						<img src="https://cdn.simpleicons.org/docker/f3efe4" alt="Docker" width="38" height="38" />
						<div class="stack-text"><span class="stack-name">Docker</span><span class="stack-desc">The whole stack in one compose file: FrankenPHP app image, Reverb websockets, queue worker &amp; scheduler</span></div>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================ FEATURES ============================ -->
		<section id="features" class="features">
			<div class="wrap">
				<div class="section-head">
					<span class="eyebrow eyebrow--gold">Everything a team needs</span>
					<h2 class="serif section-title">Built in, not add-ons</h2>
					<p class="section-lede">
						Channels, threads, and DMs are table stakes. The Desk also covers the workflow features
						teams actually miss when they leave the big platforms.
					</p>
				</div>
				<div class="feature-grid">
					<div class="feature-card">
						<div class="feature-demo demo-col">
							<span class="demo-text">Reminder: retro moved to Thursday.</span>
							<span class="scheduled-pill scheduled-pill--soft">
								<svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#b98e3f" stroke-width="2" stroke-linecap="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 6v6l4 2"></path></svg>
								Sends Mon 9:00 AM
							</span>
						</div>
						<div class="feature-text"><span class="feature-name">Scheduled messages</span><span class="feature-desc">Write now, send when it's kind to. Edit or cancel anything still in the queue.</span></div>
					</div>
					<div class="feature-card">
						<div class="feature-demo demo-row">
							<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#b98e3f" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"></path><path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"></path></svg>
							<span class="demo-text">Remind me about this <strong>tomorrow at 9 AM</strong></span>
						</div>
						<div class="feature-text"><span class="feature-name">Message reminders</span><span class="feature-desc">Snooze any message and it resurfaces exactly when you asked. Nothing slips.</span></div>
					</div>
					<div class="feature-card">
						<div class="feature-demo demo-col">
							<span class="demo-text">Starting a thread for icon feedback.</span>
							<span class="thread-link">
								<span class="stack"><span class="stack-a stack-a--sm"></span><span class="stack-b stack-b--sm"></span></span>
								5 replies
							</span>
						</div>
						<div class="feature-text"><span class="feature-name">Threads &amp; group DMs</span><span class="feature-desc">Side conversations stay at the side. Channels stay readable.</span></div>
					</div>
					<div class="feature-card">
						<div class="feature-demo demo-row">
							<span class="reaction reaction--on">🚀 7</span>
							<span class="reaction">🥳 3</span>
							<span class="reaction reaction--add">+</span>
						</div>
						<div class="feature-text"><span class="feature-name">Reactions &amp; custom emoji</span><span class="feature-desc">Upload your team's own emoji. Inside jokes are a feature, not bloat.</span></div>
					</div>
					<div class="feature-card">
						<div class="feature-demo demo-row">
							<span class="dot dot--brass"></span>
							<span class="demo-text">Reconnecting… <span class="faint">your drafts are safe</span></span>
						</div>
						<div class="feature-text"><span class="feature-name">Connection resilience</span><span class="feature-desc">Flaky wifi, laptop lids, VPN drops: The Desk reconnects and catches up quietly.</span></div>
					</div>
					<div class="feature-card">
						<div class="feature-demo demo-row">
							<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#b98e3f" stroke-width="1.8" stroke-linecap="round" aria-hidden="true"><path d="M3 3v18h18"></path><path d="M7 14l4-4 3 3 5-6"></path></svg>
							<span class="demo-text">Analytics, audit log, roles &amp; invitations</span>
						</div>
						<div class="feature-text"><span class="feature-name">Real admin tools</span><span class="feature-desc">Team analytics, a moderation audit log, roles, and session management, all included.</span></div>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================ SELF-HOST ============================ -->
		<section id="selfhost" class="selfhost">
			<div class="wrap selfhost-grid">
				<div class="selfhost-copy">
					<span class="eyebrow eyebrow--brass">Self-hosted, for real</span>
					<h2 class="serif selfhost-title">Your messages never leave your building</h2>
					<p class="selfhost-lede">
						No SaaS middleman, no data-retention lawyering, no surprise pricing changes. The Desk ships
						as one compose file with a prebuilt image. Run it on a VPS, a NAS in the closet, or your
						company's rack.
					</p>
					<ul class="checklist">
						<li>
							<svg viewBox="0 0 24 24" fill="none" stroke="#c9a35c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
							<span><strong>Unlimited everything.</strong> Members, history, file storage, bounded by your disk, not a plan.</span>
						</li>
						<li>
							<svg viewBox="0 0 24 24" fill="none" stroke="#c9a35c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
							<span><strong>Boring, auditable stack.</strong> Laravel, Vue, Postgres, Reverb, Meilisearch. No build step. Read every line on GitHub.</span>
						</li>
						<li>
							<svg viewBox="0 0 24 24" fill="none" stroke="#c9a35c" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"></path></svg>
							<span><strong>Leave anytime.</strong> Built-in data export for every user. It's your database either way.</span>
						</li>
					</ul>
				</div>
				<div class="terminal">
					<div class="terminal-bar">
						<span class="tdot"></span><span class="tdot"></span><span class="tdot"></span>
						<span class="terminal-host">you@yourserver</span>
					</div>
					<div class="terminal-body">
						<div><span class="prompt">$</span> git clone github.com/emmpaul/the-desk &amp;&amp; cd the-desk</div>
						<div><span class="prompt">$</span> ./docker/gen-secrets.sh <span class="prompt"># fills APP_KEY, DB, Reverb keys</span></div>
						<div><span class="prompt">$</span> docker compose -f docker-compose.prod.yml up -d</div>
						<div class="dim">Pulling ghcr.io/emmpaul/the-desk:0.4.0… done</div>
						<div class="dim">Running migrations… done</div>
						<div><span class="ok">✓</span> The Desk is live at <span class="ok">https://desk.your-domain.com</span></div>
						<div class="cursor-line"><span class="prompt">$</span> <span class="cursor"></span></div>
					</div>
				</div>
			</div>
		</section>

		<!-- ============================ CTA ============================ -->
		<section class="cta">
			<div class="wrap cta-inner">
				<svg width="44" height="44" viewBox="0 0 40 40" aria-hidden="true">
					<polygon points="20,18 36,27 20,36 4,27" fill="#1d1a15" opacity="0.4"></polygon>
					<polygon points="20,11 36,20 20,29 4,20" fill="#1d1a15" opacity="0.7"></polygon>
					<polygon points="20,4 36,13 20,22 4,13" fill="#c9a35c"></polygon>
				</svg>
				<h2 class="serif cta-title">Set up The Desk before your next standup</h2>
				<p class="cta-lede">Free forever, MIT licensed. If you can run a container, you can run your team's chat.</p>
				<div class="cta-actions">
					<a class="btn btn-dark btn-lg" href={installGuide}>Read the install guide</a>
					<a class="btn btn-outline btn-lg" href={github}>
						<svg width="14" height="14" viewBox="0 0 24 24" fill="#665f4e" aria-hidden="true"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.09.66-.22.66-.48v-1.7c-2.78.6-3.37-1.34-3.37-1.34-.45-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.9 1.52 2.34 1.08 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.56-1.11-4.56-4.94 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02A9.58 9.58 0 0 1 12 6.84c.85 0 1.71.11 2.51.34 1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.84-2.34 4.68-4.57 4.93.36.31.68.92.68 1.85V21c0 .27.16.58.67.48A10 10 0 0 0 22 12c0-5.52-4.48-10-10-10z"></path></svg>
						Star on GitHub
					</a>
				</div>
			</div>
		</section>

		<!-- ============================ FOOTER ============================ -->
		<footer class="footer">
			<div class="wrap footer-inner">
				<div class="footer-brand">
					<svg width="18" height="18" viewBox="0 0 40 40" aria-hidden="true">
						<polygon points="20,18 36,27 20,36 4,27" fill="#1d1a15" opacity="0.4"></polygon>
						<polygon points="20,11 36,20 20,29 4,20" fill="#1d1a15" opacity="0.7"></polygon>
						<polygon points="20,4 36,13 20,22 4,13" fill="#c9a35c"></polygon>
					</svg>
					<span class="footer-copy">The Desk · MIT License</span>
				</div>
				<nav class="footer-links">
					<a href="/docs">Docs</a>
					<a href={github}>GitHub</a>
					<a href={`${github}/releases`}>Changelog</a>
					<a href={`${github}/discussions`}>Community</a>
				</nav>
			</div>
		</footer>

		<!-- ============================ MOBILE MENU ============================ -->
		<div class="mobile-menu" id="mobileMenu" hidden>
			<div class="mobile-menu-head">
				<a class="brand" href="/">
					<svg width="24" height="24" viewBox="0 0 40 40" aria-hidden="true">
						<polygon points="20,18 36,27 20,36 4,27" fill="#1d1a15" opacity="0.4"></polygon>
