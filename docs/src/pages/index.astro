			.demo-text {
				font-size: 12px;
				line-height: 1.45;
				color: var(--ink);
			}
			.scheduled-pill--soft {
				margin-top: 0;
			}
			.feature-text {
				display: flex;
				flex-direction: column;
				gap: 4px;
			}
			.feature-name {
				font-size: 15px;
				font-weight: 650;
			}
			.feature-desc {
				font-size: 13px;
				line-height: 1.55;
				color: var(--muted);
			}

			/* self-host */
			.selfhost {
				background: var(--dark);
				color: var(--paper);
				border-bottom: 1px solid var(--line);
			}
			.selfhost-grid {
				padding: 88px 32px;
				display: grid;
				grid-template-columns: 1fr 1fr;
				gap: 64px;
				align-items: center;
			}
			.selfhost-copy {
				display: flex;
				flex-direction: column;
				gap: 18px;
			}
			.selfhost-title {
				font-size: 38px;
				font-weight: 600;
				letter-spacing: -0.015em;
				line-height: 1.15;
				color: var(--paper);
			}
			.selfhost-lede {
				font-size: 15.5px;
				line-height: 1.65;
				color: #b3ab97;
				text-wrap: pretty;
			}
			.checklist {
				list-style: none;
				padding: 0;
				display: flex;
				flex-direction: column;
				gap: 12px;
				margin-top: 6px;
			}
			.checklist li {
				display: flex;
				gap: 12px;
				align-items: flex-start;
				font-size: 14px;
				line-height: 1.5;
				color: #dedad0;
			}
			.checklist svg {
				width: 15px;
				height: 15px;
				flex-shrink: 0;
				margin-top: 2px;
			}
			.checklist strong {
				color: var(--paper);
			}
			.terminal {
				border: 1px solid var(--panel-line);
				border-radius: 14px;
				background: var(--panel);
				overflow: hidden;
				box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
			}
			.terminal-bar {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 12px 16px;
				border-bottom: 1px solid var(--panel-line);
			}
			.tdot {
				width: 10px;
				height: 10px;
				border-radius: 99px;
				background: #4a4436;
			}
			.terminal-host {
				margin-left: 8px;
				font-size: 11.5px;
				color: #8b8370;
				font-family: ui-monospace, monospace;
			}
			.terminal-body {
				padding: 20px 22px 24px;
				font-family: ui-monospace, monospace;
				font-size: 12.5px;
				line-height: 1.85;
				color: #dedad0;
				overflow-x: auto;
			}
			.terminal-body .prompt {
				color: #8b8370;
			}
			.terminal-body .dim {
				color: #8b8370;
			}
			.terminal-body .ok {
				color: var(--brass);
			}
			.cursor-line {
				margin-top: 8px;
			}
			.cursor {
				display: inline-block;
				width: 8px;
				height: 15px;
				background: var(--brass);
				vertical-align: -2px;
			}

			/* CTA */
			.cta {
				background: var(--cream);
			}
			.cta-inner {
				padding: 96px 32px 88px;
				display: flex;
				flex-direction: column;
				align-items: center;
				text-align: center;
			}
			.cta-title {
				margin-top: 24px;
				font-size: 40px;
				font-weight: 600;
				letter-spacing: -0.015em;
				line-height: 1.1;
				max-width: 560px;
				text-wrap: balance;
			}
			.cta-lede {
				margin-top: 16px;
				font-size: 15.5px;
				color: var(--muted);
				max-width: 440px;
				line-height: 1.6;
			}
			.cta-actions {
				margin-top: 30px;
				display: flex;
				align-items: center;
				gap: 12px;
			}

			/* footer */
			.footer {
				border-top: 1px solid var(--line);
				background: var(--cream);
			}
			.footer-inner {
				padding: 28px 32px;
				display: flex;
				align-items: center;
				gap: 24px;
			}
			.footer-brand {
				display: flex;
				align-items: center;
				gap: 8px;
			}
			.footer-copy {
				font-size: 13px;
				color: var(--faint);
			}
			.footer-links {
				margin-left: auto;
				display: flex;
				align-items: center;
				gap: 20px;
			}
			.footer-links a {
				font-size: 13px;
				color: var(--faint);
			}
			.footer-links a:hover {
				color: var(--ink);
			}

			/* mobile menu */
			.mobile-menu {
				position: fixed;
				inset: 0;
				z-index: 40;
				background: var(--cream);
				display: flex;
				flex-direction: column;
			}
			.mobile-menu[hidden] {
				display: none;
			}
			.mobile-menu-head {
				display: flex;
				align-items: center;
				gap: 10px;
				height: 60px;
				padding: 0 20px;
				border-bottom: 1px solid var(--line);
			}
			.mobile-menu-head .brand {
				margin-right: auto;
			}
			.mobile-menu-body {
				flex: 1;
				display: flex;
				flex-direction: column;
				padding: 20px 20px 28px;
			}
			.mobile-links {
				display: flex;
				flex-direction: column;
			}
			.mobile-links a {
				display: flex;
				align-items: center;
				height: 56px;
				border-bottom: 1px solid var(--line);
				font-family: 'Newsreader', serif;
				font-size: 24px;
				font-weight: 600;
				letter-spacing: -0.01em;
			}
			.mobile-links a svg {
				margin-left: auto;
				width: 16px;
				height: 16px;
			}
			.mobile-cta {
				margin-top: auto;
				padding-top: 24px;
				display: flex;
				flex-direction: column;
				gap: 10px;
			}

			/* ---------------- responsive ---------------- */
			@media (max-width: 860px) {
				.wrap,
				.nav-inner {
					padding-left: 20px;
					padding-right: 20px;
				}
				.nav-links {
					display: none;
				}
				.nav-toggle {
					display: inline-flex;
				}

				.hero-grid {
					grid-template-columns: 1fr;
					gap: 0;
				}
				.hero-copy {
					padding: 44px 0 0;
				}
				.hero-title {
					font-size: 38px;
					line-height: 1.08;
				}
				.hero-lede {
					font-size: 15px;
				}
				.hero-actions {
					align-self: stretch;
					flex-direction: column;
				}
				.hero-actions .btn {
					width: 100%;
					height: 48px;
				}
				.hero-install {
					align-self: center;
					align-items: center;
					text-align: center;
					margin-top: 14px;
				}

				.preview {
					width: 100%;
					margin-top: 32px;
					padding: 10px 10px 0;
					border-radius: 14px 14px 0 0;
				}
				.preview-panes {
					height: 320px;
				}
				.pane-dock,
				.pane-thread {
					display: none;
				}
				.pane-timeline {
					border-radius: 10px 10px 0 0;
				}

				.powered-grid {
					grid-template-columns: 1fr;
					gap: 22px;
					padding: 52px 20px 56px;
				}
				.powered-intro {
					position: static;
				}
				.powered-title {
					font-size: 27px;
				}
				.stack-grid {
					grid-template-columns: 1fr 1fr;
				}

				.features .wrap {
					padding-top: 52px;
					padding-bottom: 56px;
					gap: 24px;
				}
				.section-title {
					font-size: 27px;
				}
				.feature-grid {
					grid-template-columns: 1fr;
					gap: 12px;
				}

				.selfhost-grid {
					grid-template-columns: 1fr;
					gap: 28px;
					padding: 52px 20px 56px;
				}
				.selfhost-title {
					font-size: 27px;
				}

				.cta-inner {
					padding: 60px 20px;
				}
				.cta-title {
					font-size: 28px;
				}
				.cta-actions {
					align-self: stretch;
					flex-direction: column;
				}
				.cta-actions .btn {
					width: 100%;
					height: 48px;
				}

				.footer-inner {
					flex-direction: column;
					align-items: flex-start;
					gap: 16px;
				}
				.footer-links {
					margin-left: 0;
					flex-wrap: wrap;
					gap: 16px;
				}
			}

			@media (min-width: 861px) {
				.mobile-menu {
					display: none !important;
				}
			}
		</style>
	</body>
</html>
