#!/usr/bin/env bash
#
# bin/worktree — per-worktree Sail isolation so multiple agents can implement
# issues concurrently (see issue #441).
#
# Git worktrees already isolate the working tree and Sail already isolates
# containers/network/volumes per Compose project (keyed off COMPOSE_PROJECT_NAME).
# The only things that collide across concurrent worktrees are host port bindings
# and per-worktree vendor/ + node_modules/. This script hands each worktree a
# unique port block and its own Compose project, and installs its deps.
#
# The test gate only touches Postgres (phpunit.xml: cache/session=array,
# queue=sync, scout=collection, broadcast=null), but the bootstrap itself runs
# artisan against the worktree's own .env, where CACHE_STORE/QUEUE_CONNECTION are
# redis — the demo seed reaches the cache through CreateChannel/JoinChannel and
# dies on an unstarted `redis` host otherwise (issue #723). So an isolated
# worktree runs `laravel.test` + `pgsql` + `redis`: a generated
# compose.override.yaml trims laravel.test's depends_on to those two backing
# services, and `sail up -d laravel.test` then starts those three containers only.
#
# The Browser suite (tests/Browser) is the exception: it drives a real Chromium
# and points the broadcaster at a live Reverb. So the bootstrap also installs the
# Playwright browsers into the app container and brings `reverb` up — four
# containers in total.
#
# Because the worktree's .env is copied from the main checkout, it can name
# services those four don't include (the opt-in `sso` profile's ldap/oidc,
# mailpit, meilisearch); write_env points those settings somewhere harmless so
# the isolated instance is usable rather than half-wired. The database it starts
# on is empty, so the bootstrap also migrates and seeds it.
#
# Subcommands:
#   create <NNN> [base]   Create (or re-enter) an isolated worktree for issue NNN.
#                         Prints the worktree's absolute path on stdout so it is
#                         composable:  cd "$(bin/worktree create 441)"
#                         `base` is the branch to fork from (default: master).
#                         It is fetched and forked from its remote-tracking ref
#                         when it has one, so a stale local branch of the same
#                         name cannot be inherited as the baseline.
#   list                  Show active worktrees with their slots and ports.
#   remove <NNN>          Tear down containers + volumes, remove the git worktree,
#                         and free the registry slot. Leaves the branch intact.
#
# Config (environment overrides):
#   WORKTREE_SLOTS        Number of concurrent slots (default 10).
#   WORKTREE_PORT_BASE    First host port; each slot gets a 10-port block from
#                         here (default 20000 => slot 0 uses 20000-20003).
#   WORKTREE_BASE         Default base branch for `create` (default master).
#   WORKTREE_COMPOSER_IMAGE  Throwaway image used only to produce vendor/ before
#                            ./vendor/bin/sail exists in a fresh worktree. NOT the
#                            app runtime (that is the php8.5 sail-8.5/app image).
#                            Defaults to laravelsail/php84-composer:latest — the
#                            highest composer image Sail publishes (php85-composer
#                            is not on Docker Hub yet); composer.json only needs
#                            php ^8.3 and the resulting vendor/ runs on php8.5.
#
# All diagnostics go to stderr; only machine-readable output (the worktree path
# from `create`, the table from `list`) goes to stdout.

set -euo pipefail

SLOTS="${WORKTREE_SLOTS:-10}"
PORT_BASE="${WORKTREE_PORT_BASE:-20000}"
DEFAULT_BASE="${WORKTREE_BASE:-master}"
COMPOSER_IMAGE="${WORKTREE_COMPOSER_IMAGE:-laravelsail/php84-composer:latest}"

# The compose services a worktree ever brings up: `sail up -d laravel.test` with
# the trimmed depends_on, plus reverb. Every other service in compose.yaml stays
# down, so the generated .env must not point at one (see write_env);
# tests/Unit/WorktreeScriptTest.php holds that line.
WORKTREE_STARTED_SERVICES="laravel.test pgsql reverb redis"

REGISTRY_DIR="${HOME}/.the-desk"
REGISTRY_FILE="${REGISTRY_DIR}/worktrees.json"
LOCK_DIR="${REGISTRY_DIR}/worktrees.lock"

log() { printf '%s\n' "$*" >&2; }
die() { printf 'error: %s\n' "$*" >&2; exit 1; }

# --- git anchoring -----------------------------------------------------------
# Resolve the MAIN working tree from the shared .git dir, so the script behaves
# identically whether invoked from the main checkout or from inside a worktree.
git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "not inside a git repository"
GIT_COMMON_DIR="$(cd "$(git rev-parse --git-common-dir)" && pwd)"
MAIN_ROOT="$(dirname "$GIT_COMMON_DIR")"
WORKTREES_DIR="$(dirname "$MAIN_ROOT")/the-desk-worktrees"

# --- tooling checks ----------------------------------------------------------
# Called from main(), not at load time, so the script can be sourced as a library
# (WORKTREE_LIB=1) by tests that only drive its git helpers.
require_tooling() {
    command -v jq >/dev/null 2>&1 || die "jq is required (brew install jq)"
    command -v docker >/dev/null 2>&1 || die "docker is required"
    # This script drives Compose v2 (`docker compose`, not the legacy v1
    # `docker-compose`) and relies on the `!override` merge tag (Compose >= 2.24).
    docker compose version >/dev/null 2>&1 || die "Docker Compose v2 is required ('docker compose' subcommand not found)"
    require_compose_version
}

require_compose_version() {
    local ver major minor rest
    ver="$(docker compose version --short 2>/dev/null | sed 's/^v//')"
    [ -n "$ver" ] || return 0 # can't determine version; the version check above already passed
    major="${ver%%.*}"; rest="${ver#*.}"; minor="${rest%%.*}"
    case "$major" in ''|*[!0-9]*) return 0 ;; esac
    case "$minor" in ''|*[!0-9]*) minor=0 ;; esac
    if [ "$major" -lt 2 ] || { [ "$major" -eq 2 ] && [ "$minor" -lt 24 ]; }; then
        die "Docker Compose >= 2.24 is required for the '!override' merge tag (found ${ver})"
    fi
}

# --- registry + locks --------------------------------------------------------
ensure_registry() {
    mkdir -p "$REGISTRY_DIR"
    [ -f "$REGISTRY_FILE" ] || printf '{}\n' > "$REGISTRY_FILE"
}

# Two mkdir-based locks (flock is absent on macOS), released together by a single
# EXIT trap set in main():
#   - the global registry lock guards find_free_slot + registry mutations so two
#     DIFFERENT issues never grab the same slot;
#   - a per-issue lock serialises the whole create/remove of ONE issue, so a
#     stray second `create NNN` (or a create racing a remove) can't run git,
#     Composer, Sail or npm concurrently on the same worktree. Different issues
#     take different per-issue locks, so cross-issue concurrency is preserved.
HELD_REGISTRY_LOCK=""
HELD_ISSUE_LOCK=""

acquire_lock() {
    local tries=0
    while ! mkdir "$LOCK_DIR" 2>/dev/null; do
        tries=$((tries + 1))
        if [ "$tries" -gt 200 ]; then
            die "could not acquire registry lock at ${LOCK_DIR}; if no other worktree command is running, remove it and retry"
        fi
        sleep 0.1
    done
    HELD_REGISTRY_LOCK=1
}

# Only removes LOCK_DIR when THIS process currently owns it, so an explicit
# mid-flow release (or the EXIT trap firing after one) can never delete a lock
# another process has since acquired.
release_lock() {
    [ -n "$HELD_REGISTRY_LOCK" ] || return 0
    rmdir "$LOCK_DIR" 2>/dev/null || true
    HELD_REGISTRY_LOCK=""
}

acquire_issue_lock() {
    local nnn="$1" lock="${REGISTRY_DIR}/locks/${1}.lock" tries=0
    mkdir -p "${REGISTRY_DIR}/locks"
    while ! mkdir "$lock" 2>/dev/null; do
        tries=$((tries + 1))
        if [ "$tries" -gt 6000 ]; then
            die "another 'worktree' command has been working on #${nnn} for >10m (lock ${lock}); wait for it, or remove the lock if it is stale"
        fi
        sleep 0.1
    done
    HELD_ISSUE_LOCK="$lock"
}

# Release both locks; safe to call unconditionally from the EXIT trap.
release_all_locks() {
    release_lock
    [ -n "$HELD_ISSUE_LOCK" ] && rmdir "$HELD_ISSUE_LOCK" 2>/dev/null
    HELD_ISSUE_LOCK=""
    return 0
}

registry_get() { jq -r --arg k "$1" '.[$k] // empty' "$REGISTRY_FILE"; }

registry_set() {
    local nnn="$1" obj="$2" tmp
    tmp="$(mktemp)"
    jq --arg k "$nnn" --argjson v "$obj" '.[$k] = $v' "$REGISTRY_FILE" > "$tmp"
    mv "$tmp" "$REGISTRY_FILE"
}

registry_del() {
    local nnn="$1" tmp
    tmp="$(mktemp)"
    jq --arg k "$nnn" 'del(.[$k])' "$REGISTRY_FILE" > "$tmp"
    mv "$tmp" "$REGISTRY_FILE"
}

# Lowest slot integer in [0, SLOTS) not claimed by an existing entry.
find_free_slot() {
    local s
    for ((s = 0; s < SLOTS; s++)); do
        if ! jq -e --argjson s "$s" 'any(.[]; .slot == $s)' "$REGISTRY_FILE" >/dev/null; then
            printf '%s' "$s"
            return 0
        fi
    done
    return 1
}

# --- helpers -----------------------------------------------------------------
slugify() {
    printf '%s' "$1" \
        | tr '[:upper:]' '[:lower:]' \
        | sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//' \
        | cut -c1-50 \
        | sed -E 's/-+$//'
}

validate_issue() {
    # Positive integer in canonical form: no zero, no leading zeroes, all digits.
    case "$1" in
        ''|0*|*[!0-9]*) die "issue number must be a positive integer without leading zeroes, got: '$1'" ;;
    esac
}

# Resolve a base branch to an unambiguous ref to fork from.
#
# `git worktree add -b <new> <path> <base>` looks safe but DWIMs when <base>
# matches no local branch and exactly one remote-tracking branch: git then
# creates a local <base> tracking the remote and checks THAT out, silently
# dropping -b. The worktree ends up on the shared release line, and every commit
# made in it lands there (issue #619). Naming the remote-tracking ref explicitly
# disables the guess, so resolve the base before handing it to git.
#
# The remote copy also WINS over a local branch of the same name: a local
# `develop` that is merely behind origin silently forks the worktree from a
# stale baseline, and the omission only surfaces later as a conflict or a
# missing commit (issue #639). The local branch is used only when the base
# exists nowhere on a remote.
resolve_base_ref() {
    local base="$1"

    # HEAD/@ name the current checkout, but refs/remotes/*/HEAD exists in any
    # clone, so the remote lookup below would silently redirect them to
    # origin/HEAD.
    if [ "$base" = "HEAD" ] || [ "$base" = "@" ]; then
        git -C "$MAIN_ROOT" rev-parse --verify --quiet "${base}^{commit}" >/dev/null \
            || die "base '${base}' does not resolve to a commit"
        printf '%s' "$base"
        return 0
    fi

    # Refresh the remote-tracking refs so the branch below is the remote's
    # current tip rather than whatever the last fetch left behind. Failures
    # (offline, no such branch on that remote) are non-fatal: resolution then
    # falls back to the refs already in the clone.
    local remote
    while read -r remote; do
        [ -n "$remote" ] || continue
        git -C "$MAIN_ROOT" fetch --quiet "$remote" "$base" >/dev/null 2>&1 || true
    done <<< "$(git -C "$MAIN_ROOT" remote)"

    local remote_refs count
    remote_refs="$(git -C "$MAIN_ROOT" for-each-ref --format='%(refname:short)' "refs/remotes/*/${base}")"
    count="$(printf '%s' "$remote_refs" | grep -c . || true)"
    if [ "$count" -eq 1 ]; then
        printf '%s' "$remote_refs"
        return 0
    fi
    if [ "$count" -gt 1 ]; then
        die "base '${base}' is ambiguous — it exists on several remotes ($(printf '%s' "$remote_refs" | tr '\n' ' ')); pass the remote-tracking ref explicitly"
    fi

    # Not a branch name: accept anything git can resolve to a commit (a tag, a
    # SHA, or an already-qualified ref such as origin/develop).
    git -C "$MAIN_ROOT" rev-parse --verify --quiet "${base}^{commit}" >/dev/null \
        || die "base '${base}' does not exist locally or on any remote (fetch it first?)"
    printf '%s' "$base"
}

# Put $path on branch $branch, forking from $base when the branch is new, and
# refuse to continue unless the worktree really is on that branch.
attach_worktree() {
    local path="$1" branch="$2" base="$3"
    if [ ! -d "$path" ]; then
        if git -C "$MAIN_ROOT" show-ref --verify --quiet "refs/heads/${branch}"; then
            log "attaching existing branch ${branch}"
            git -C "$MAIN_ROOT" worktree add "$path" "$branch"
        else
            local base_ref
            base_ref="$(resolve_base_ref "$base")"
            log "creating branch ${branch} from ${base_ref}"
            git -C "$MAIN_ROOT" worktree add -b "$branch" "$path" "$base_ref"
        fi
    fi

    local head
    head="$(git -C "$path" rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
    [ "$head" = "$branch" ] || die "worktree ${path} is on '${head:-<unknown>}', expected '${branch}' — refusing to continue, commits would land on the wrong branch"
}

# Insert or replace KEY=VALUE in an env file.
upsert_env() {
    local file="$1" key="$2" value="$3"
    if grep -qE "^${key}=" "$file"; then
        local tmp
        tmp="$(mktemp)"
        sed -E "s|^${key}=.*|${key}=${value}|" "$file" > "$tmp"
        mv "$tmp" "$file"
    else
        printf '%s=%s\n' "$key" "$value" >> "$file"
    fi
}

# --- create ------------------------------------------------------------------
# A worktree is "ready" once a .worktree-ready sentinel exists. Re-entry is fast
# when ready and resumes the (idempotent) bootstrap when a prior run was
# interrupted before the sentinel was written.
cmd_create() {
    local nnn="${1:-}" base="${2:-$DEFAULT_BASE}"
    validate_issue "$nnn"
    ensure_registry

    # Serialise the entire create for this issue (held until the EXIT trap fires),
    # so a second `create NNN` re-enters instead of racing the bootstrap.
    acquire_issue_lock "$nnn"

    # --- resolve the entry (fast re-entry, or allocate a slot) under lock -----
    acquire_lock
    local entry path slot app_port vite_port reverb_port db_port slug branch project
    entry="$(registry_get "$nnn")"
    if [ -n "$entry" ]; then
        path="$(printf '%s' "$entry" | jq -r '.path')"
        if [ -d "$path" ] && [ -f "${path}/.worktree-ready" ]; then
            release_lock
            log "worktree for #${nnn} already ready — re-entering ${path}"
            printf '%s\n' "$path"
            return 0
        fi
        if [ ! -d "$path" ]; then
            log "registry entry for #${nnn} points at missing ${path}; re-creating"
            registry_del "$nnn"
            entry=""
        fi
    fi

    if [ -n "$entry" ]; then
        # Registered but not yet ready: resume the same slot/path.
        slot="$(printf '%s' "$entry" | jq -r '.slot')"
        slug="$(printf '%s' "$entry" | jq -r '.slug')"
        branch="$(printf '%s' "$entry" | jq -r '.branch')"
        project="$(printf '%s' "$entry" | jq -r '.project')"
        app_port="$(printf '%s' "$entry" | jq -r '.ports.app')"
        vite_port="$(printf '%s' "$entry" | jq -r '.ports.vite')"
        reverb_port="$(printf '%s' "$entry" | jq -r '.ports.reverb')"
        db_port="$(printf '%s' "$entry" | jq -r '.ports.db')"
        release_lock
        log "resuming interrupted bootstrap for #${nnn} at ${path}"
    else
        slot="$(find_free_slot)" || { release_lock; die "all ${SLOTS} worktree slots are in use; free one with 'bin/worktree remove <NNN>'"; }

        # Derive the whole port block from the slot integer.
        local block=$((PORT_BASE + slot * 10))
        app_port=$block vite_port=$((block + 1)) reverb_port=$((block + 2)) db_port=$((block + 3))

        local title
        title="$(gh issue view "$nnn" --json title --jq .title 2>/dev/null || true)"
        slug="$(slugify "${title:-issue-$nnn}")"
        [ -n "$slug" ] || slug="issue-$nnn"

        branch="${nnn}-${slug}"
        path="${WORKTREES_DIR}/${nnn}-${slug}"
        project="desk-${nnn}"
        local created_at
        created_at="$(date -u +%Y-%m-%dT%H:%M:%SZ)"

        # Claim the slot under lock, then release before the slow install work.
        local obj
        obj="$(jq -n \
            --argjson issue "$nnn" \
            --argjson slot "$slot" \
            --arg slug "$slug" \
            --arg branch "$branch" \
            --arg path "$path" \
            --arg project "$project" \
            --argjson app "$app_port" \
            --argjson vite "$vite_port" \
            --argjson reverb "$reverb_port" \
            --argjson db "$db_port" \
            --arg created_at "$created_at" \
            '{issue: $issue, slot: $slot, slug: $slug, branch: $branch, path: $path, project: $project, ports: {app: $app, vite: $vite, reverb: $reverb, db: $db}, created_at: $created_at}')"
        registry_set "$nnn" "$obj"
        release_lock
    fi

    # Derived rather than stored: the whole block comes from the slot anyway, and
    # deriving keeps registry entries written by older versions readable on resume.
    local redis_port=$((db_port + 1))

    log "issue #${nnn} -> slot ${slot} (project ${project}); ports app=${app_port} vite=${vite_port} reverb=${reverb_port} db=${db_port} redis=${redis_port}"

    # --- git worktree (idempotent) -------------------------------------------
    mkdir -p "$WORKTREES_DIR"
    attach_worktree "$path" "$branch" "$base"

    # --- .env (generated once; preserves manual edits on resume) -------------
    if [ ! -f "${path}/.env" ]; then
        local env_source="${MAIN_ROOT}/.env"
        if [ ! -f "$env_source" ]; then
            log "no .env in main checkout; falling back to .env.example"
            env_source="${path}/.env.example"
        fi
        write_env "$path" "$env_source" "$app_port" "$vite_port" "$db_port" "$redis_port" "$project"
    fi

    # --- compose override -----------------------------------------------------
    write_override "$path" "$nnn" "$reverb_port"

    # --- dependencies ---------------------------------------------------------
    # The lightweight composer image lacks the app's runtime extensions
    # (gd/imagick/ldap/sockets) and cannot run Laravel's post-install scripts, so
    # it only bootstraps enough vendor/ to obtain ./vendor/bin/sail; the
    # authoritative install then runs inside the php8.5 app container below.
    if [ ! -x "${path}/vendor/bin/sail" ]; then
        log "bootstrapping vendor/ via ${COMPOSER_IMAGE} to obtain Sail"
        docker run --rm \
            -u "$(id -u):$(id -g)" \
            -v "${path}:/var/www/html" \
            -w /var/www/html \
            "$COMPOSER_IMAGE" \
            composer install --no-interaction --prefer-dist --no-progress \
                --ignore-platform-reqs --no-scripts
    fi

    log "starting laravel.test + pgsql + redis (building image on first run may take a while)"
    (cd "$path" && ./vendor/bin/sail up -d laravel.test)

    log "finalizing PHP dependencies inside the app container (runs post-install scripts)"
    (cd "$path" && ./vendor/bin/sail composer install --no-interaction)

    if grep -qE '^APP_KEY=$' "${path}/.env"; then
        log "generating APP_KEY"
        (cd "$path" && ./vendor/bin/sail artisan key:generate --force)
    fi

    migrate_and_seed "$path"

    log "installing JS dependencies via Sail (Linux-only native bindings)"
    (cd "$path" && ./vendor/bin/sail npm install --no-progress)

    install_playwright_browsers "$path"

    # The Browser suite points the broadcaster at the reverb container
    # (tests/Pest.php calls useReverbForBrowserTests for the whole suite), so a
    # worktree that can only run Unit+Feature is not enough. Started here rather
    # than through laravel.test's depends_on so it boots after APP_KEY exists —
    # reverb:start exits on a missing key and nothing would restart it.
    log "starting reverb for the Browser suite"
    (cd "$path" && ./vendor/bin/sail up -d reverb)

    # The feature suite renders Inertia pages, which fail with a 500 unless a Vite
    # manifest exists, so a testable worktree must build assets. Regenerate the
    # git-ignored App.Data/App.Enums ambient types first (the transformer needs
    # its output dir to exist) so the build resolves the `App` namespace — mirrors
    # the CI ordering in .github/workflows/tests.yml.
    log "generating TypeScript types and building frontend assets (Vite manifest)"
    mkdir -p "${path}/resources/js/generated"
    (cd "$path" && ./vendor/bin/sail artisan typescript:transform)
    (cd "$path" && ./vendor/bin/sail npm run build)

    touch "${path}/.worktree-ready"
    log "worktree ready — cd into it and run: ./vendor/bin/sail composer test"
    printf '%s\n' "$path"
}

# Playwright ships its browser binaries out of band: `npm install` fetches the
# driver but not Chromium, so every tests/Browser run in a fresh worktree dies
# with "Playwright is outdated" (issue #579). The shared libraries Chromium links
# against are installed with apt and need root, hence root-shell; the browser
# itself installs as the sail user so it is readable by the test run. Both steps
# are slow, so skip them when the build is already unpacked — that keeps
# re-entry fast.
#
# Where "unpacked" is depends on PLAYWRIGHT_BROWSERS_PATH (the Sail image pins it
# to 0, which means inside node_modules rather than a shared ~/.cache), so ask
# Playwright itself where the build belongs instead of hardcoding a directory.
PLAYWRIGHT_PROBE='loc=$(npx playwright install --dry-run chromium 2>/dev/null | sed -n "s/^ *Install location: *//p" | head -1); [ -n "$loc" ] && [ -d "$loc" ]'

# Each worktree gets its own Postgres volume, so the bootstrap starts on an empty
# database and the login form has no account to accept — signing in to the
# isolated instance is the point (issue #680). The seed is guarded by its own
# sentinel because WorkspaceSeeder builds a fresh fixture workspace on each run;
# migrations still run on every later entry so a rebased worktree picks up new ones.
#
# Until that sentinel exists the schema is rebuilt rather than migrated in place.
# A seed that dies partway through — as it did whenever it ran before redis was
# up (issue #723) — leaves rows behind, and the next `create` then dies on
# `duplicate key value violates unique constraint "users_email_unique"` instead
# of resuming. Dropping the tables first is safe precisely because the sentinel
# is missing: no seed has ever completed against them.
migrate_and_seed() {
    local path="$1"

    if [ -f "${path}/.worktree-seeded" ]; then
        log "running database migrations (demo workspace already seeded)"
        (cd "$path" && ./vendor/bin/sail artisan migrate --force)
        return 0
    fi

    log "migrating a fresh database and seeding the demo workspace"
    (cd "$path" && ./vendor/bin/sail artisan migrate:fresh --seed --force)
    touch "${path}/.worktree-seeded"
}

install_playwright_browsers() {
    local path="$1"

    if (cd "$path" && ./vendor/bin/sail shell -c "$PLAYWRIGHT_PROBE" >/dev/null 2>&1); then
        log "Playwright chromium already present — skipping browser install"
        return 0
    fi

    log "installing Playwright chromium and its system dependencies"
    (cd "$path" && ./vendor/bin/sail root-shell -c "npx playwright install-deps chromium")
    (cd "$path" && ./vendor/bin/sail npx playwright install chromium)
}

# Copy $source to the worktree's .env, offsetting the ports it publishes on the
# host and pinning the ones that are container-internal.
write_env() {
    local path="$1" source="$2" app_port="$3" vite_port="$4" db_port="$5" redis_port="$6" project="$7"

    cp "$source" "${path}/.env"
    upsert_env "${path}/.env" APP_PORT "$app_port"
    upsert_env "${path}/.env" VITE_PORT "$vite_port"
    upsert_env "${path}/.env" FORWARD_DB_PORT "$db_port"
    # reverb pulls redis in through its own depends_on, and redis publishes
    # '${FORWARD_REDIS_PORT:-6379}:6379' — so without an offset the second
    # worktree to start reverb dies on "Bind for :::6379 failed".
    upsert_env "${path}/.env" FORWARD_REDIS_PORT "$redis_port"
    upsert_env "${path}/.env" COMPOSE_PROJECT_NAME "$project"
    upsert_env "${path}/.env" APP_URL "http://localhost:${app_port}"

    # REVERB_PORT is overloaded in compose.yaml: it is BOTH the host side of
    # '${REVERB_PORT}:8080' and — via config/broadcasting.php — the port the app
    # dials at reverb:<port>. Offsetting it per worktree therefore points the
    # broadcaster at a port nothing listens on, and the realtime browser tests
    # hang. Pin the container-internal value (the reverb container is started
    # with --port=8080) and let write_override remap the host side instead.
    upsert_env "${path}/.env" REVERB_PORT 8080

    # Auth toggles inherited from the main checkout can strip the register
    # route (config/fortify.php gates Features::registration() on
    # REGISTRATION_ENABLED / AUTH_SSO_ONLY / DEMO_MODE), and without it
    # Wayfinder never emits resources/js/routes/register, so the bootstrap's
    # `npm run build` dies on an unresolvable import (issue #563). Force the
    # registration-friendly defaults; like the port overrides above, this
    # only runs when generating a fresh .env, so a manually edited worktree
    # .env is preserved on resume.
    upsert_env "${path}/.env" DEMO_MODE false
    upsert_env "${path}/.env" REGISTRATION_ENABLED true
    upsert_env "${path}/.env" AUTH_SSO_ONLY false

    detach_unstarted_services "${path}/.env"
}

# Point every setting that names a compose service away from the ones a worktree
# never starts (WORKTREE_STARTED_SERVICES).
#
# The main checkout's .env is copied verbatim, so a developer running the opt-in
# `sso` profile hands the worktree LDAP_HOST=ldap with no ldap container behind
# it — and Fortify then fails EVERY password login with "Can't contact LDAP
# server", which reads as an app bug rather than a bootstrap one (issue #680).
# The same trap is set by MAIL_HOST=mailpit and MEILISEARCH_HOST, so each one is
# disabled the way its config already supports: blank hosts switch SSO off
# (config/sso.php gates on `filled()`), and mail/search fall back to drivers that
# need no container.
detach_unstarted_services() {
    local file="$1"

    # Nothing should re-enable the profile services either, whatever the main
    # checkout was running.
    upsert_env "$file" COMPOSE_PROFILES ""

    upsert_env "$file" LDAP_HOST ""
    upsert_env "$file" SSO_OIDC_ISSUER ""
    upsert_env "$file" SSO_OIDC_CLIENT_ID ""
    upsert_env "$file" SSO_OIDC_DISCOVERY_URL ""

    upsert_env "$file" MAIL_MAILER log
    upsert_env "$file" MAIL_HOST ""

    upsert_env "$file" SCOUT_DRIVER collection
    upsert_env "$file" MEILISEARCH_HOST ""
}

write_override() {
    local path="$1" nnn="$2" reverb_port="$3"
    cat > "${path}/compose.override.yaml" <<EOF
# Generated by bin/worktree for issue #${nnn} — do not edit by hand.
#
# Trims laravel.test to the essentials: the gate only touches Postgres
# (phpunit.xml uses array/sync/collection/null drivers) and the bootstrap's own
# artisan calls only add redis (the worktree .env runs cache and queue on it), so
# meilisearch, mailpit and queue are never needed. With depends_on cut to pgsql
# and redis, \`sail up -d laravel.test\` starts exactly three containers. The
# Browser suite additionally needs a live WebSocket server, so bin/worktree
# starts reverb as a separate step.
#
# .env pins REVERB_PORT to the container-internal 8080 because the app dials
# reverb:\${REVERB_PORT}; the per-worktree host offset lives here instead, so
# concurrent worktrees still don't fight over the host port.
#
# Other host ports and COMPOSE_PROJECT_NAME are offset per worktree in .env;
# Compose auto-loads this override file alongside compose.yaml.
services:
    laravel.test:
        depends_on: !override
            - pgsql
            - redis
    reverb:
        ports: !override
            - '${reverb_port}:8080'
EOF
}

# --- list --------------------------------------------------------------------
cmd_list() {
    ensure_registry
    local count
    count="$(jq 'length' "$REGISTRY_FILE")"
    if [ "$count" -eq 0 ]; then
        log "no active worktrees"
        return 0
    fi
    local rows
    rows="$(
        printf 'ISSUE\tSLOT\tAPP\tVITE\tREVERB\tDB\tBRANCH\tPATH\n'
        jq -r '
            to_entries
            | sort_by(.value.slot)
            | .[]
            | .value
            | [ (.issue|tostring), (.slot|tostring), (.ports.app|tostring), (.ports.vite|tostring), (.ports.reverb|tostring), (.ports.db|tostring), .branch, .path ]
            | @tsv
        ' "$REGISTRY_FILE"
    )"
    # Prefer aligned columns; fall back to raw TSV where `column` is unavailable.
    if command -v column >/dev/null 2>&1; then
        printf '%s\n' "$rows" | column -t -s "$(printf '\t')"
    else
        printf '%s\n' "$rows"
    fi
}

# --- remove ------------------------------------------------------------------
cmd_remove() {
    local nnn="${1:-}"
    validate_issue "$nnn"
    ensure_registry

    # Hold the per-issue lock across the whole teardown so a concurrent
    # `create NNN` cannot slot in a replacement entry that we would then delete.
    acquire_issue_lock "$nnn"

    acquire_lock
    local entry
    entry="$(registry_get "$nnn")"
    release_lock
    [ -n "$entry" ] || die "no worktree registered for #${nnn}"

    local path project
    path="$(printf '%s' "$entry" | jq -r '.path')"
    project="$(printf '%s' "$entry" | jq -r '.project')"

    log "tearing down containers + volumes for project ${project}"
    docker compose -p "$project" -f "${MAIN_ROOT}/compose.yaml" down --volumes --remove-orphans 2>/dev/null || \
        log "compose teardown reported nothing to remove (already down?)"

    if [ -d "$path" ]; then
        log "removing git worktree ${path}"
        git -C "$MAIN_ROOT" worktree remove --force "$path" 2>/dev/null || log "git worktree remove skipped (${path} not a registered worktree?)"
    fi
    git -C "$MAIN_ROOT" worktree prune

    acquire_lock
    registry_del "$nnn"
    release_lock
    log "freed slot for #${nnn} (branch left intact)"
}

# --- dispatch ----------------------------------------------------------------
usage() {
    cat >&2 <<'EOF'
usage: bin/worktree <command> [args]

  create <NNN> [base]   Create (or re-enter) an isolated worktree for issue NNN.
                        Prints its absolute path:  cd "$(bin/worktree create 441)"
  list                  Show active worktrees, slots and ports.
  remove <NNN>          Tear down the worktree's containers/volumes and free its slot.
EOF
    exit 64
}

main() {
    # EXIT runs the cleanup on any exit; INT/TERM just trigger an exit (with the
    # conventional 128+signal code) so an interrupted run can't resume bootstrap
    # or teardown without its locks.
    trap release_all_locks EXIT
    trap 'exit 130' INT
    trap 'exit 143' TERM

    require_tooling

    local cmd="${1:-}"
    [ -n "$cmd" ] || usage
    shift
    case "$cmd" in
        create) cmd_create "$@" ;;
        list)   cmd_list "$@" ;;
        remove) cmd_remove "$@" ;;
        -h|--help|help) usage ;;
        *) die "unknown command: ${cmd} (try create|list|remove)" ;;
    esac
}

# Sourcing with WORKTREE_LIB=1 defines the helpers without dispatching a
# subcommand, so tests can drive them directly (tests/Unit/WorktreeScriptTest.php).
[ -n "${WORKTREE_LIB:-}" ] || main "$@"
